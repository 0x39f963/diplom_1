# ------------------------- eva-agent-lab - пример окружения -------------------------
# Скопируй в .env и заполни. .env под .gitignore - секреты в git НЕ попадают.
# ВНИМАНИЕ: выпусти ОТДЕЛЬНЫЙ OpenRouter-ключ на этот проект (не переиспользуй чужой).

# -- LLM: OpenRouter --
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_PROVIDER_ONLY=          # опц.: pin upstream-провайдера для стабильности
QWEN_THINKING_FORCE_ON=false         # true - НЕ глушить qwen3-thinking (по умолчанию глушим: иначе 11-54с/вызов)

# -- LLM: локальный Ollama (host-native, GPU на WSL2) --
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1   # из контейнера к host-Ollama
HOST_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1          # host-only smoke
LOCAL_LLM_API_KEY=not-needed
OLLAMA_KEEP_ALIVE=30m                # резидентность модели на сервере Ollama
OLLAMA_REQUEST_KEEP_ALIVE=30m        # per-request keep_alive (дефолт в коде 0s - для интерактива ставим 30m/-1)

# -- Роли узлов: какая модель и backend на каждой роли --
# backend: openrouter | local | claude_cli | codex_cli
LLM_BACKEND_REASONING=openrouter
LLM_MODEL_REASONING=qwen/qwen3.5-9b
LLM_EFFORT_REASONING=medium
LLM_BACKEND_DEFAULT=local
LLM_MODEL_DEFAULT=qwen3.5:9b
LLM_EFFORT_DEFAULT=medium
LLM_BACKEND_GUARD=openrouter         # guard - ДРУГАЯ модель (диверсификация защиты)
LLM_MODEL_GUARD=qwen/qwen3.5-9b
LLM_EFFORT_GUARD=medium
LLM_CALL_TIMEOUT_SEC=300
LLM_PROVIDER_MAX_RETRIES=2

# -- LLM: локальные CLI-агенты --
EVA_CLI_CLAUDE_BIN=claude
EVA_CLI_CODEX_BIN=codex

# Пресет: массовый прогон Claude Sonnet
# LLM_BACKEND_REASONING=claude_cli
# LLM_MODEL_REASONING=sonnet
# LLM_EFFORT_REASONING=medium
# LLM_BACKEND_DEFAULT=claude_cli
# LLM_MODEL_DEFAULT=sonnet
# LLM_EFFORT_DEFAULT=low
# LLM_BACKEND_GUARD=claude_cli
# LLM_MODEL_GUARD=sonnet
# LLM_EFFORT_GUARD=low

# Пресет: сильный прогон Claude Opus high
# LLM_BACKEND_REASONING=claude_cli
# LLM_MODEL_REASONING=opus
# LLM_EFFORT_REASONING=high
# LLM_BACKEND_DEFAULT=claude_cli
# LLM_MODEL_DEFAULT=opus
# LLM_EFFORT_DEFAULT=high

# Пресет: сильный прогон Claude Opus medium
# LLM_BACKEND_REASONING=claude_cli
# LLM_MODEL_REASONING=opus
# LLM_EFFORT_REASONING=medium
# LLM_BACKEND_DEFAULT=claude_cli
# LLM_MODEL_DEFAULT=opus
# LLM_EFFORT_DEFAULT=medium

# Пресет: Codex GPT-5.5 medium
# LLM_BACKEND_REASONING=codex_cli
# LLM_MODEL_REASONING=gpt-5.5
# LLM_EFFORT_REASONING=medium
# LLM_BACKEND_DEFAULT=codex_cli
# LLM_MODEL_DEFAULT=gpt-5.5
# LLM_EFFORT_DEFAULT=medium

# Пресет: Codex GPT-5.8 high
# LLM_BACKEND_REASONING=codex_cli
# LLM_MODEL_REASONING=gpt-5.8
# LLM_EFFORT_REASONING=high
# LLM_BACKEND_DEFAULT=codex_cli
# LLM_MODEL_DEFAULT=gpt-5.8
# LLM_EFFORT_DEFAULT=high

# -- Поиск по закону (отдельный сервис, адрес ниже) --
RAG_API_BASE=http://localhost:8077

# -- Данные системы (read-only): backend с авто-fallback на мок --
EVA_MOCK_MODE=fixtures               # fixtures (детерминир., для бенчмарка) | random (для демо)
EVA_API_BASE=mock                    # mock | http://localhost:8082 (реальный backend read-only)
# Для реального backend раскомментируй (иначе авто-fallback на мок при раздаче исходников):
# EVA_API_BASE=http://localhost:8082
EVA_LOGIN=demo@example.local
# EVA_PASSWORD=<dev-пароль backend>

# -- Observability --
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# -- Графа --
MAX_LOOPS=2                          # лимит цикла supervisor-critic-rework
