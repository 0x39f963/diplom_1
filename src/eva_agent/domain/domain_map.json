{
  "chains": [
    "стороны Contract->ContractParty(role)->Counterparty",
    "контрагенты Contract->ContractParty->Counterparty dedup",
    "размещения Contract->Placement(+Creative)",
    "документы Contract->Document missing",
    "вчера неподписанные Contract date=вчера,status!=registered"
  ],
  "entities": {
    "Contract": {
      "description": "договор",
      "endpoints": [
        "GET /api/contracts",
        "GET /api/contracts/{id}"
      ],
      "fields": [
        "id",
        "contract_number",
        "contract_date",
        "contract_type",
        "chain_role",
        "ord_status"
      ],
      "tools": [
        "eva_list_unsigned_contracts",
        "eva_search_contracts",
        "eva_get_contract"
      ]
    },
    "ContractParty": {
      "description": "сторона договора",
      "endpoints": [
        "GET /api/contracts/{id}/parties"
      ],
      "fields": [
        "id",
        "contract_id",
        "counterparty_id",
        "role",
        "ord_status"
      ],
      "tools": [
        "eva_get_contract_parties"
      ]
    },
    "Counterparty": {
      "description": "контрагент",
      "endpoints": [
        "GET /api/counterparties/{id}"
      ],
      "fields": [
        "id",
        "name",
        "inn",
        "legal_type",
        "ord_registration_status"
      ],
      "tools": [
        "eva_get_counterparty"
      ]
    },
    "Creative": {
      "description": "креатив",
      "endpoints": [
        "GET /api/creatives/{id}"
      ],
      "fields": [
        "id",
        "title",
        "distribution_form",
        "ord_status",
        "erid_token",
        "contract_id"
      ],
      "tools": [
        "eva_get_creative_status"
      ]
    },
    "CreativeMedia": {
      "description": "файл креатива",
      "endpoints": [
        "GET /api/creatives/{id}/media"
      ],
      "fields": [
        "id",
        "creative_id",
        "file_name",
        "mime_type",
        "size",
        "url"
      ],
      "tools": [
        "eva_get_creative_status"
      ]
    },
    "Document": {
      "description": "документ",
      "endpoints": [
        "GET /api/contracts/{id}/documents",
        "POST /api/contracts/{id}/documents"
      ],
      "fields": [
        "id",
        "entity_type",
        "entity_id",
        "doc_type",
        "file_name",
        "status",
        "url"
      ],
      "tools": [
        "eva_list_contract_documents",
        "eva_doc_read",
        "eva_doc_download"
      ]
    },
    "Placement": {
      "description": "размещение",
      "endpoints": [
        "GET /api/contracts/{id}/placements",
        "GET /api/placements?contract_id="
      ],
      "fields": [
        "id",
        "contract_id",
        "creative_id",
        "status",
        "period",
        "platform"
      ],
      "tools": [
        "eva_list_placements"
      ]
    }
  },
  "relations": [
    {
      "cardinality": "many",
      "selector": "role",
      "source_entity": "ContractParty",
      "source_path": "parties[].counterparty_id",
      "source_tool": "eva_get_contract_parties",
      "target_arg": "counterparty_id",
      "target_entity": "Counterparty",
      "target_tool": "eva_get_counterparty"
    },
    {
      "cardinality": "one",
      "selector": null,
      "source_entity": "Creative",
      "source_path": "contract_id",
      "source_tool": "eva_get_creative_status",
      "target_arg": "contract_id",
      "target_entity": "Contract",
      "target_tool": "eva_get_contract"
    },
    {
      "cardinality": "one",
      "selector": null,
      "source_entity": "Contract",
      "source_path": "id",
      "source_tool": "eva_get_contract",
      "target_arg": "contract_id",
      "target_entity": "Placement",
      "target_tool": "eva_list_placements"
    },
    {
      "cardinality": "one",
      "selector": null,
      "source_entity": "Contract",
      "source_path": "id",
      "source_tool": "eva_get_contract",
      "target_arg": "contract_id",
      "target_entity": "Document",
      "target_tool": "eva_list_contract_documents"
    }
  ],
  "version": 1
}
